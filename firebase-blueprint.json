{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" },
        "timeWindow": { "type": "object" },
        "recoveryGuides": { "type": "array", "items": { "type": "object" } },
        "availabilitySlots": { "type": "array", "items": { "$ref": "AvailabilitySlot" } },
        "coordinates": { "type": "object", "description": "GeoPoint as { latitude, longitude }" },
        "geohash": { "type": "string", "description": "Geohash string for searching" },
        "recycleNotes": { "type": "string" },
        "vehicles": { "type": "array", "items": { "type": "string" } },
        "maxDistance": { "type": "number", "description": "Maximum distance the Ray is willing to travel for resource collection in kilometers" }
      },
      "required": ["displayName", "email", "roles"]
    },
    "AvailabilitySlot": {
      "title": "Availability Slot",
      "description": "A time slot when the user is available",
      "type": "object",
      "properties": {
        "dayOfWeek": { "type": "integer", "description": "0-6 (Sun-Sat)" },
        "startTime": { "type": "string", "description": "HH:mm" },
        "endTime": { "type": "string", "description": "HH:mm" }
      },
      "required": ["dayOfWeek", "startTime", "endTime"]
    },
    "RecoveryRecord": {
      "title": "Recovery Record",
      "description": "A record of recyclable materials",
      "type": "object",
      "properties": {
        "materialCategory": { "type": "string" },
        "productCategory": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string", "description": "Unit of quantity of recyclable resources" },
        "aiSuggestion": { "type": "string" },
        "imageUrl": { "type": "string" },
        "address": { "type": "string" },
        "timeWindow": { "type": "object" },
        "coordinates": { "type": "object" },
        "geohash": { "type": "string" },
        "recycleNotes": { "type": "string" },
        "makerFishId": { "type": "string" },
        "candidateGoingHomeIds": { "type": "array", "items": { "type": "string" } },
        "selectedGoingHomeId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "statusUpdatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["materialCategory", "productCategory", "quantity", "imageUrl", "address", "coordinates", "makerFishId", "status", "createdAt"]
    },
    "GoingHomePlan": {
      "title": "Going Home Plan",
      "description": "A collection route plan for a Ray",
      "type": "object",
      "properties": {
        "goingHomeId": { "type": "string" },
        "departureTime": { "type": "string", "format": "date-time" },
        "transportationType": { "type": "string" },
        "stops": { "type": "array", "items": { "type": "object" } },
        "routePolyline": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["goingHomeId", "departureTime", "stops", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notifications",
      "type": "object",
      "properties": {
        "receiverId": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "recordId": { "type": "string" },
        "planId": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["receiverId", "type", "title", "content", "isRead", "createdAt"]
    },
    "MasterDataResource": {
      "title": "Recyclable Resource Master Data",
      "description": "Lookup table for recyclable resources",
      "type": "object",
      "properties": {
        "material": { "type": "string" },
        "product": { "type": "string" },
        "defaultSuggestion": { "type": "string" },
        "icon": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "carbonReduced": { "type": "number", "description": "Carbon reduction benefit of recycling 1 unit of this category in grams" },
        "unit": { "type": "string", "description": "Counting unit of this resource category, e.g. 瓶, 片, 公升" }
      },
      "required": ["material", "product", "defaultSuggestion"]
    },
    "NewMasterDataResource": {
      "title": "Suggested Recyclable Resource",
      "description": "Crowdsourced suggestions for recyclable resources awaiting admin moderation",
      "type": "object",
      "properties": {
        "material": { "type": "string" },
        "product": { "type": "string" },
        "defaultSuggestion": { "type": "string" },
        "icon": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "suggestedBy": { "type": "string" },
        "suggestedByEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "carbonReduced": { "type": "number", "description": "Carbon reduction benefit of recycling 1 unit of this category in grams" },
        "unit": { "type": "string", "description": "Counting unit of this resource category, e.g. 瓶, 片, 公升" }
      },
      "required": ["material", "product", "defaultSuggestion", "suggestedBy", "createdAt"]
    },
    "Config": {
      "title": "System Configuration",
      "description": "System-wide settings and test accounts",
      "type": "object",
      "properties": {
        "accounts": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "uid": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        }
      }
    },
    "SystemLog": {
      "title": "System Log",
      "description": "System trace log for backend, frontend errors, API calls and troubleshooting",
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["info", "warn", "error"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "service": { "type": "string" },
        "details": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" }
      },
      "required": ["level", "message", "timestamp"]
    },
    "RecycleContract": {
      "title": "Recycle Contract",
      "description": "Recycling contract between a Maker Fish, Going Home Ray, and Recycler",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending Signatures", "Active", "Rejected", "Suspended"] },
        "templateRecord": { 
          "type": "object",
          "properties": {
            "materialCategory": { "type": "string" },
            "productCategory": { "type": "string" },
            "quantity": { "type": "number" },
            "unit": { "type": "string" }
          },
          "required": ["materialCategory", "productCategory", "quantity", "unit"]
        },
        "schedule": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
            "daysOfWeek": { "type": "array", "items": { "type": "integer" } },
            "dayOfMonth": { "type": "integer" },
            "time": { "type": "string" },
            "scheduleText": { "type": "string" }
          },
          "required": ["type", "time", "scheduleText"]
        },
        "makerFishId": { "type": "string" },
        "goingHomeId": { "type": "string" },
        "recyclerId": { "type": "string" },
        "signatures": {
          "type": "object",
          "properties": {
            "makerFish": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
            "goingHome": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
            "recycler": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] }
          },
          "required": ["makerFish", "goingHome", "recycler"]
        },
        "rejectionReason": { "type": "string" },
        "sourceRecordId": { "type": "string" },
        "lastGeneratedAt": { "type": "string", "format": "date-time" },
        "nextRunAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["creatorId", "status", "templateRecord", "schedule", "makerFishId", "goingHomeId", "recyclerId", "signatures", "createdAt", "updatedAt"]
    },
    "ContractHistory": {
      "title": "Contract History",
      "description": "Audit log for changes made to a contract",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "operatorId": { "type": "string" },
        "operatorName": { "type": "string" },
        "operatorRole": { "type": "string" },
        "action": { "type": "string" },
        "note": { "type": "string" }
      },
      "required": ["timestamp", "operatorId", "operatorName", "operatorRole", "action"]
    },
    "ContractMessage": {
      "title": "Contract Message",
      "description": "Communication messages between parties of a contract",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "senderRole", "content", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings"
    },
    "recoveryRecords/{recordId}": {
      "schema": "RecoveryRecord",
      "description": "Recycling records created by Maker Fish"
    },
    "goingHomePlans/{planId}": {
      "schema": "GoingHomePlan",
      "description": "Route plans created by Rays"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System notifications for users"
    },
    "masterData_resources/{resourceId}": {
      "schema": "MasterDataResource",
      "description": "Authority data for resource types"
    },
    "newMasterData_resources/{suggestedId}": {
      "schema": "NewMasterDataResource",
      "description": "Suggested resource types submitted by users"
    },
    "config/{configId}": {
      "schema": "Config",
      "description": "System configuration documents"
    },
    "systemLogs/{logId}": {
      "schema": "SystemLog",
      "description": "System-wide diagnostic and event logs"
    },
    "recycleContracts/{contractId}": {
      "schema": "RecycleContract",
      "description": "Recycling contracts between parties"
    },
    "recycleContracts/{contractId}/history/{historyId}": {
      "schema": "ContractHistory",
      "description": "Auditing trails of a contract"
    },
    "recycleContracts/{contractId}/messages/{messageId}": {
      "schema": "ContractMessage",
      "description": "Discussion and chat logs of a contract"
    }
  }
}
